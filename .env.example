# ─────────────────────────────────────────────────
# NSRIT eSports Arena — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Django core
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ── DATABASE ──────────────────────────────────────
# Leave blank to use SQLite (development)
# Set to postgres://user:pass@host:port/dbname for production
DATABASE_URL=

# ── EMAIL (Gmail SMTP) ────────────────────────────
# In DEBUG=True mode, emails are printed to the console (no SMTP needed)
# For production, fill these in:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=NSRIT eSports Arena <noreply@nsrit.edu.in>

# ── ADMIN SECURITY ────────────────────────────────
# Change this to something secret in production!
# Example: ADMIN_URL=nsrit-control-x9k2mq/
# The admin panel will ONLY be accessible at /<ADMIN_URL>
# Anyone visiting /admin/ will get a 404 if you change this.
ADMIN_URL=admin/

# ── RAZORPAY ──────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret

# ── RENDER DEPLOYMENT ─────────────────────────────────────────────
# These are set automatically by Render via render.yaml — do NOT set manually
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# ── CSRF (auto-built from RENDER_EXTERNAL_HOSTNAME in settings.py) ─
# Set manually only if using a custom domain:
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
